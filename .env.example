# Copy this file to .env and fill in your credentials.
# Keep .env private. It is intentionally ignored by Git.

WEBULL_APP_KEY=
WEBULL_APP_SECRET=

# Use "uat" with Webull's shared test credentials, or "prod" for your real account.
WEBULL_ENV=prod
WEBULL_REGION=us

# Personal app access gate. Set APP_PASSWORD in Railway before exposing the app.
APP_USERNAME=sushanth
APP_PASSWORD=

# Optional. If you already have a reusable access token from Webull's 2FA flow,
# place it here. Otherwise the SDK may initiate Webull's token verification flow.
WEBULL_ACCESS_TOKEN=

# Optional. SDK token cache directory. Use /data/.webull-token on Railway with
# a mounted volume; local default is .webull-token.
WEBULL_TOKEN_DIR=.webull-token

# Optional emergency override. Keep enabled unless you need one manual retry.
WEBULL_GUARD_ENABLED=true
WEBULL_GUARD_FILE=.webull-guard.json

# Optional. Enables closed-app phone push notifications for MTF changes.
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sushanth@example.com
PUSH_SUBSCRIPTION_FILE=.web-push-subscriptions.json
MTF_PUSH_POLL_SECONDS=30
MTF_PUSH_TIMEZONE=America/Chicago
